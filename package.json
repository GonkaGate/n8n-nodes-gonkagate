{
	"name": "@gonkagate/n8n-nodes-gonkagate",
	"version": "0.2.2",
	"description": "n8n community node package for GonkaGate root-node and chat-model workflows.",
	"homepage": "https://github.com/GonkaGate/n8n-nodes-gonkagate#readme",
	"bugs": {
		"url": "https://github.com/GonkaGate/n8n-nodes-gonkagate/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/GonkaGate/n8n-nodes-gonkagate.git"
	},
	"license": "MIT",
	"author": {
		"name": "GonkaGate"
	},
	"type": "commonjs",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"check:bootstrap": "node scripts/check-bootstrap.mjs",
		"check:docker-image-smoke": "node scripts/check-docker-image-smoke.mjs",
		"check:publish-context": "node scripts/check-publish-context.mjs",
		"check:self-hosted-smoke": "node scripts/check-self-hosted-smoke.mjs",
		"dev": "n8n-node dev",
		"format:check": "prettier --check .",
		"format:write": "prettier --write .",
		"lint": "npm run format:check && npm run check:bootstrap",
		"lint:fix": "npm run format:write",
		"lint:n8n": "n8n-node lint",
		"build:n8n": "n8n-node build",
		"release": "n8n-node release",
		"test:unit": "rm -rf .test-dist && tsc -p tsconfig.unit.json && node --test .test-dist/tests/**/*.test.js",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"ci": "npm run lint && npm run typecheck && npm run build && npm run test:unit",
		"prepublishOnly": "npm run check:publish-context"
	},
	"keywords": [
		"n8n-community-node-package",
		"gonkagate",
		"gonka",
		"gonka gateway",
		"chat model",
		"openai-compatible",
		"n8n"
	],
	"packageManager": "npm@11.11.1",
	"n8n": {
		"n8nNodesApiVersion": 1,
		"aiNodeSdkVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/GonkaGateApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/GonkaGate/GonkaGate.node.js",
			"dist/nodes/LmChatGonkaGate/LmChatGonkaGate.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.24.0",
		"ai-node-sdk": "npm:@n8n/ai-node-sdk@0.4.1",
		"eslint": "^9.39.4",
		"prettier": "^3.8.1",
		"release-it": "^19.2.4",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"ai-node-sdk": "npm:@n8n/ai-node-sdk@0.4.1",
		"n8n-workflow": "*"
	},
	"overrides": {
		"@n8n/ai-utilities@0.7.1": {
			"@langchain/classic": "1.0.25",
			"@langchain/community": "1.1.25",
			"@langchain/core": "1.1.39"
		},
		"@n8n/ai-utilities@0.8.1": {
			"@langchain/classic": "1.0.25",
			"@langchain/community": "1.1.25",
			"@langchain/core": "1.1.39"
		},
		"@langchain/community@1.1.25": {
			"ignore": "7.0.5"
		},
		"@typescript-eslint/typescript-estree": {
			"minimatch": "9.0.7"
		},
		"handlebars": "4.7.9",
		"lodash": "4.18.1",
		"release-it": {
			"undici": "6.24.1"
		}
	}
}
